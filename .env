# StreamSrv — environment config
# This file is loaded automatically on server startup

# PostgreSQL (required for accounts, chat history, stream history)
# Format: postgres://USER:PASSWORD@HOST/DBNAME?sslmode=disable
DATABASE_URL=postgres://postgres:200555@localhost/streamdb?sslmode=disable

# JWT secret — change to a long random string in production
JWT_SECRET=change-me-to-something-long-and-random

# Redis (optional)
# REDIS_URL=redis://localhost:6379

# Server port
PORT=8080